{
  "name": "kai-code-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kai": "./dist/cli/main.js"
  },
  "scripts": {
    "dev": "bun src/cli/main.ts",
    "kai": "bun src/cli/main.ts",
    "kai:node": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:bun": "bun test"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.0.2",
    "react": "^19.2.6",
    "react-devtools-core": "^7.0.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
